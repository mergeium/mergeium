{
    "name": "@mergeium/auth",
    "version": "0.0.0",
    "private": true,
    "description": "Keycloakify authentication theme",
    "type": "module",
    "scripts": {
        "dev": "keycloakify start-keycloak --keycloak-version 26.5.5",
        "build": "tsc && vite build",
        "build-keycloak-theme": "pnpm run build && keycloakify build",
        "storybook": "storybook dev -p 6006",
        "lint": "biome check .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit"
    },
    "license": "MIT",
    "dependencies": {
        "@mergeium/ui": "workspace:*",
        "keycloakify": "^11.15.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@storybook/react": "^8.1.10",
        "@storybook/react-vite": "^8.1.10",
        "@tailwindcss/postcss": "^4.1.18",
        "@tailwindcss/vite": "^4.1.18",
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@vitejs/plugin-react": "^4.2.1",
        "storybook": "^8.1.10",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.2.2",
        "vite": "^5.0.8"
    }
}
